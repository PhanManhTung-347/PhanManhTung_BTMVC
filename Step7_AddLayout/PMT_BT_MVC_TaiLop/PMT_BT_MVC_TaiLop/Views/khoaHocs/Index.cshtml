@model IEnumerable<PMT_Baitap_MVCTaiLop.Models.KhoaHoc>
<div class="container mt-4">
    <h2 class="text-primary">Danh sách Khóa học</h2>
    <p><a asp-action="Create" class="btn btn-success">Thêm khóa học mới</a></p>
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Mã KH</th>
                <th>Tên Khóa Học</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.KhoaHocId</td>
                    <td>@item.tenKH</td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.KhoaHocId" class="btn btn-warning btn-sm">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.KhoaHocId" class="btn btn-danger btn-sm" onclick="return confirm('Xóa khóa học này?')">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>